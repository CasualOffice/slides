{
  "name": "casual-slides",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev:web": "pnpm --filter @point/web dev",
    "build:web": "pnpm --filter @point/web build",
    "typecheck": "pnpm -r typecheck",
    "test:unit": "pnpm -r --workspace-concurrency=1 test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:collab": "playwright test --config=playwright.collab.config.ts",
    "dev:server": "pnpm --filter @point/server dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jszip": "^3.10.1",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@univerjs/slides@0.24.0": "patches/@univerjs__slides@0.24.0.patch",
      "@univerjs/slides-ui@0.24.0": "patches/@univerjs__slides-ui@0.24.0.patch",
      "@univerjs/engine-render@0.24.0": "patches/@univerjs__engine-render@0.24.0.patch",
      "@univerjs/core@0.24.0": "patches/@univerjs__core@0.24.0.patch"
    }
  }
}
